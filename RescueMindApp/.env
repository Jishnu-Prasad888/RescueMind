# RescueMind — Environment Variables
# Place this file at your Expo project root as .env

# Google Maps API Key (used for Directions API + map rendering)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
# Nominatim (geocoding): add a contact URL and/or From email per
# https://operations.osmfoundation.org/policies/nominatim/
EXPO_PUBLIC_NOMINATIM_CONTACT=https://github.com/Jishnu-Prasad888/RescueMind
EXPO_PUBLIC_NOMINATIM_FROM_EMAIL=thisisjishnuprasad888@gmail.com
