OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=DisasterRAG

# Model string — any model available on OpenRouter works here.
# See full list at https://openrouter.ai/models
# Good options:
#   anthropic/claude-3.5-sonnet     (best tool-calling, default)
#   openai/gpt-4o
#   meta-llama/llama-3.1-70b-instruct  (open-source, cheaper)
#   mistralai/mistral-large
OPENROUTER_MODEL=openrouter/free


# ------------------------------------------------------------
# Weather  [RECOMMENDED]
# Get a free key at https://openweathermap.org/api
# Without this, the weather tool returns a graceful error.
# ------------------------------------------------------------
WEATHERAPI_KEY=e177a9a027904144a25130812262003

# ------------------------------------------------------------
# News  [OPTIONAL]
# Get a free key at https://newsapi.org
# Without this, news tool still works via RSS (ReliefWeb, GDACS).
